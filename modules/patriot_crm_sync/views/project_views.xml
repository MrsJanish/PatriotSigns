<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Project Kanban: Click opens project form, not task list
         ============================================================ -->
    <record id="view_project_kanban_open_form" model="ir.ui.view">
        <field name="name">project.project.kanban.open_form</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_kanban"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <kanban position="attributes">
                <attribute name="action"></attribute>
                <attribute name="type"></attribute>
                <attribute name="js_class"></attribute>
            </kanban>
        </field>
    </record>

    <!-- ============================================================
         Project Form: Add CRM-synced fields in a dedicated tab
         ============================================================ -->
    <record id="view_project_form_crm_sync" model="ir.ui.view">
        <field name="name">project.project.form.crm_sync</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">

            <!-- Add a "CRM / Contract" tab to the notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="CRM / Contract" name="crm_contract_page">
                    <group string="Contract Details">
                        <group>
                            <field name="x_studio_project_bid" string="Linked CRM Lead" readonly="1"/>
                            <field name="x_studio_contract_amount" string="Contract Amount" widget="monetary"/>
                            <field name="x_studio_contract_no" string="Contract No."/>
                            <field name="x_studio_project_contract_number" string="Project/Contract No."/>
                            <field name="x_studio_contract_date" string="Contract Date"/>
                        </group>
                        <group>
                            <field name="x_studio_retainage_percentage" string="Retainage %" widget="percentage"/>
                            <field name="x_studio_warranty_period" string="Warranty Period"/>
                            <field name="x_studio_billing" string="Billing"/>
                            <field name="x_studio_payapp_due_date" string="Pay App Due Date"/>
                            <field name="x_studio_sequence" string="GC Project No."/>
                        </group>
                    </group>
                    <group string="Project Info">
                        <group>
                            <field name="x_studio_project_stage_sync" string="Project Stage"/>
                            <field name="x_studio_city_state" string="City / State"/>
                            <field name="x_studio_opportunity_customer" string="Owner"/>
                            <field name="x_studio_project_alias" string="Project Alias"/>
                        </group>
                        <group>
                            <field name="x_studio_needs_attention" string="Needs Attention" widget="boolean_toggle"/>
                            <field name="x_studio_team_contacts" string="Team Contacts" widget="many2many_tags"/>
                        </group>
                    </group>
                </page>

                <page string="Sign Types" name="sign_types_page">
                    <field name="x_studio_related_field_ke_1ibpjr5k8" string="Sign Types" readonly="1">
                        <tree>
                            <field name="x_name" string="Sign Type"/>
                            <field name="x_studio_quantity" string="Qty"/>
                            <field name="x_studio_category" string="Category"/>
                        </tree>
                    </field>
                </page>

                <page string="Locations" name="locations_page">
                    <field name="x_studio_locations" string="Locations" readonly="1">
                        <tree>
                            <field name="x_name" string="Location"/>
                        </tree>
                    </field>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
